# Generated by `make setup` — or copy and edit manually.

# Used for Terraform `repo_url` (cloud-init downloads bootstrap from this repo on GitHub).
# Setup writes this from `git remote origin`. Override if needed.
GITHUB_REPO=YOUR_USERNAME/astroneer-server-kit

SSH_KEY=~/.ssh/astro-server

# Written by `make setup` — shown in-game (AstroServerSettings.ini ServerName); Terraform state bucket name is derived from this.
# ASTRONEER_SERVER_NAME=My Astroneer Server

# Vultr compute plan slug (e.g. vc2-4c-8gb) — chosen in setup’s plan step.
# VULTR_PLAN=vc2-4c-8gb

# Vultr API (setup also provisions Object Storage + writes S3 keys below)
VULTR_API_KEY=

# Filled automatically by `make setup` (terraform/bootstrap + S3 bucket for remote state; name derived from server display name)
VULTR_S3_BUCKET=astroneer-terraform-state
VULTR_S3_ACCESS_KEY=
VULTR_S3_SECRET_KEY=
VULTR_S3_ENDPOINT=

# Optional — same region as object storage + compute (default ewr)
# VULTR_REGION=ewr

# Rare — if Object Storage bootstrap errors on cluster lookup, pin a cluster id (numeric) from:
#   curl -s -H "Authorization: Bearer $VULTR_API_KEY" https://api.vultr.com/v2/object_storage/clusters
# `make` exports `.env`, so TF_VAR_* is visible to the bootstrap Terraform run.
# TF_VAR_object_storage_cluster_id=
