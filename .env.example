# Copy to .env or run `make setup` (recommended).

# Optional — for status/repo links
# GITHUB_REPO=yourname/astroneer-server-kit

# Set by setup: Fly app name (slug) and org API token (fly tokens create org)
# FLY_APP_NAME=
# FLY_API_TOKEN=

# Region for Machines + volume (default ord if omitted)
# FLY_REGION=ord

# VM memory slug written into fly.toml (e.g. 8gb)
# FLY_VM_MEMORY=8gb

# In-game ServerName / ASTRONEER_SERVER_NAME — also embedded in fly.toml [env]
# ASTRONEER_SERVER_NAME=My Astroneer Server

# Optional — if automatic PublicIP detection fails for joins, set after deploy:
# fly secrets set ASTRONEER_PUBLIC_IP=x.x.x.x -a YOUR_APP
