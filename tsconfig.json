{
  "compilerOptions": {
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "moduleResolution": "bundler",
    "module": "esnext",
    "target": "esnext",
    "strict": true,
    "esModuleInterop": true,
    "types": ["bun-types"],
    "skipLibCheck": true
  },
  "include": ["scripts/**/*"]
}
