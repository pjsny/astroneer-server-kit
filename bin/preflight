#!/bin/bash
# Preflight check — verifies everything is configured before starting the server.

REPO_ROOT="$(cd "$(dirname "$0")/.." && pwd)"

GREEN='\033[0;32m'
RED='\033[0;31m'
YELLOW='\033[1;33m'
BOLD='\033[1m'
RESET='\033[0m'

PASS=0
FAIL=0

ok()   { echo -e "  ${GREEN}✓${RESET}  $1"; ((PASS++)); }
fail() { echo -e "  ${RED}✗${RESET}  $1"; ((FAIL++)); }
warn() { echo -e "  ${YELLOW}!${RESET}  $1"; }

echo ""
echo -e "${BOLD}  Astroneer Server Kit — Preflight Check${RESET}"
echo "  ─────────────────────────────────────────"
echo ""

# Load .env if present
[ -f "$REPO_ROOT/.env" ] && source "$REPO_ROOT/.env"

# ── Tools ──────────────────────────────────────────────────────────────────────

echo -e "${BOLD}  Tools${RESET}"
command -v terraform &>/dev/null && ok "terraform" || fail "terraform not installed  →  brew install terraform"
command -v gh        &>/dev/null && ok "gh CLI"    || fail "gh CLI not installed    →  brew install gh"
command -v ssh       &>/dev/null && ok "ssh"       || fail "ssh not found"
echo ""

# ── Auth ───────────────────────────────────────────────────────────────────────

echo -e "${BOLD}  Auth${RESET}"
gh auth status &>/dev/null && ok "GitHub CLI authenticated" || fail "Not logged into GitHub  →  gh auth login"

if [ -n "$DO_TOKEN" ]; then
  STATUS=$(curl -s -o /dev/null -w "%{http_code}" \
    -H "Authorization: Bearer $DO_TOKEN" \
    "https://api.digitalocean.com/v2/account")
  [ "$STATUS" = "200" ] && ok "DO token valid" || fail "DO token invalid or expired"
else
  fail "DO_TOKEN not set  →  run: bash bin/setup"
fi
echo ""

# ── SSH key ────────────────────────────────────────────────────────────────────

echo -e "${BOLD}  SSH Key${RESET}"
SSH_KEY="${SSH_KEY:-$HOME/.ssh/astro-server}"
if [ -f "$SSH_KEY" ] && [ -f "$SSH_KEY.pub" ]; then
  ok "SSH key found at $SSH_KEY"
else
  fail "SSH key not found at $SSH_KEY  →  run: bash bin/setup"
fi
echo ""

# ── GitHub secrets ─────────────────────────────────────────────────────────────

echo -e "${BOLD}  GitHub Secrets${RESET}"
REQUIRED_SECRETS=("DO_TOKEN" "DO_SPACES_KEY" "DO_SPACES_SECRET" "SSH_PUBLIC_KEY" "SSH_PRIVATE_KEY")
for secret in "${REQUIRED_SECRETS[@]}"; do
  if gh secret list 2>/dev/null | grep -q "^$secret"; then
    ok "$secret"
  else
    fail "$secret not set  →  run: bash bin/setup"
  fi
done
echo ""

# ── Terraform state ────────────────────────────────────────────────────────────

echo -e "${BOLD}  Infrastructure${RESET}"

# Check state bucket
BUCKET_STATUS=$(curl -s -o /dev/null -w "%{http_code}" \
  -H "Authorization: AWS ${DO_SPACES_KEY}:${DO_SPACES_SECRET}" \
  "https://nyc3.digitaloceanspaces.com/astro-server-tf-state" 2>/dev/null || echo "000")

if [ "$BUCKET_STATUS" = "200" ] || [ "$BUCKET_STATUS" = "403" ]; then
  ok "Terraform state bucket exists"
else
  fail "State bucket not found  →  run: bash bin/setup"
fi

# Check saves volume via DO API
if [ -n "$DO_TOKEN" ]; then
  VOLUME=$(curl -s \
    -H "Authorization: Bearer $DO_TOKEN" \
    "https://api.digitalocean.com/v2/volumes?name=astro-saves" \
    | grep -o '"astro-saves"' || echo "")
  [ -n "$VOLUME" ] && ok "Saves volume exists" || fail "Saves volume not found  →  run: bash bin/setup"

  # Check if server is currently running
  DROPLET=$(curl -s \
    -H "Authorization: Bearer $DO_TOKEN" \
    "https://api.digitalocean.com/v2/droplets?name=astro-server" \
    | grep -o '"astro-server"' || echo "")
  if [ -n "$DROPLET" ]; then
    warn "Server is currently running"
  else
    ok "Server is stopped (expected when idle)"
  fi
fi
echo ""

# ── Summary ────────────────────────────────────────────────────────────────────

if [ "$FAIL" -eq 0 ]; then
  echo -e "  ${GREEN}${BOLD}All checks passed! Run 'make start' to spin up the server.${RESET}"
else
  echo -e "  ${RED}${BOLD}$FAIL check(s) failed. Run 'bash bin/setup' to fix.${RESET}"
fi
echo ""
