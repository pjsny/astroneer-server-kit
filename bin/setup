#!/bin/bash
# Astroneer Server Kit — Interactive Setup Wizard
# Run this once to configure everything.

set -e

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
BOLD='\033[1m'
RESET='\033[0m'

REPO_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
HETZNER_S3_ENDPOINT="https://fsn1.your-objectstorage.com"
STATE_BUCKET="astro-server-tf-state"

info()    { echo -e "${CYAN}==>${RESET} $1"; }
success() { echo -e "${GREEN}✓${RESET}  $1"; }
warn()    { echo -e "${YELLOW}!${RESET}  $1"; }
error()   { echo -e "${RED}✗${RESET}  $1"; exit 1; }
prompt()  { echo -e "${BOLD}$1${RESET}"; }

echo ""
echo -e "${BOLD}  Astroneer Server Kit — Setup${RESET}"
echo "  ────────────────────────────────"
echo "  This will configure your Hetzner server"
echo "  and GitHub Actions in about 5 minutes."
echo ""

# ── Check prereqs ──────────────────────────────────────────────────────────────

info "Checking prerequisites..."

MISSING=()
command -v terraform &>/dev/null || MISSING+=("terraform  →  brew install terraform")
command -v gh        &>/dev/null || MISSING+=("gh CLI     →  brew install gh")
command -v aws       &>/dev/null || MISSING+=("aws CLI    →  brew install awscli")
command -v ssh-keygen &>/dev/null || MISSING+=("ssh-keygen →  included with macOS/Linux")

if [ ${#MISSING[@]} -gt 0 ]; then
  echo ""
  echo -e "${RED}Missing required tools:${RESET}"
  for m in "${MISSING[@]}"; do echo "  • $m"; done
  echo ""
  error "Install the above and re-run setup."
fi

success "All tools installed"

# Check gh auth
if ! gh auth status &>/dev/null; then
  echo ""
  warn "You need to authenticate with GitHub first."
  gh auth login || error "GitHub auth failed."
fi
success "GitHub CLI authenticated"

REPO=$(gh repo view --json nameWithOwner -q .nameWithOwner 2>/dev/null || echo "")
[ -z "$REPO" ] && error "Not inside a GitHub repo. Push this repo to GitHub first."
success "GitHub repo: $REPO"

echo ""

# ── Hetzner credentials ────────────────────────────────────────────────────────

info "Hetzner credentials"
echo ""
echo "  Cloud API token: https://console.hetzner.cloud → project → Security → API Tokens"
echo "  Object Storage keys: https://console.hetzner.cloud → project → Security → S3 Credentials"
echo ""

if [ -z "$HCLOUD_TOKEN" ]; then
  prompt "  Hetzner Cloud API Token:"
  read -rs HCLOUD_TOKEN
  echo ""
fi
[ -z "$HCLOUD_TOKEN" ] && error "HCLOUD_TOKEN is required."
success "Hetzner API token set"

if [ -z "$HETZNER_S3_ACCESS_KEY" ]; then
  echo ""
  prompt "  Hetzner Object Storage Access Key:"
  read -r HETZNER_S3_ACCESS_KEY
fi
[ -z "$HETZNER_S3_ACCESS_KEY" ] && error "HETZNER_S3_ACCESS_KEY is required."

if [ -z "$HETZNER_S3_SECRET_KEY" ]; then
  prompt "  Hetzner Object Storage Secret Key:"
  read -rs HETZNER_S3_SECRET_KEY
  echo ""
fi
[ -z "$HETZNER_S3_SECRET_KEY" ] && error "HETZNER_S3_SECRET_KEY is required."

success "Object Storage credentials set"
echo ""

# ── SSH key ────────────────────────────────────────────────────────────────────

SSH_KEY="$HOME/.ssh/astro-server"

if [ -f "$SSH_KEY" ]; then
  success "SSH key already exists at $SSH_KEY"
else
  info "Generating SSH key..."
  ssh-keygen -t ed25519 -f "$SSH_KEY" -N "" -C "astroneer-server"
  success "SSH key created at $SSH_KEY"
fi
echo ""

# ── Create Object Storage bucket ───────────────────────────────────────────────

info "Creating Terraform state bucket..."

BUCKET_EXISTS=$(AWS_ACCESS_KEY_ID="$HETZNER_S3_ACCESS_KEY" \
  AWS_SECRET_ACCESS_KEY="$HETZNER_S3_SECRET_KEY" \
  aws s3api head-bucket \
    --bucket "$STATE_BUCKET" \
    --endpoint-url "$HETZNER_S3_ENDPOINT" \
    --region fsn1 2>&1 || echo "not-found")

if echo "$BUCKET_EXISTS" | grep -q "not-found\|NoSuchBucket\|404"; then
  AWS_ACCESS_KEY_ID="$HETZNER_S3_ACCESS_KEY" \
  AWS_SECRET_ACCESS_KEY="$HETZNER_S3_SECRET_KEY" \
  aws s3api create-bucket \
    --bucket "$STATE_BUCKET" \
    --endpoint-url "$HETZNER_S3_ENDPOINT" \
    --region fsn1 2>&1 | tail -2
  success "State bucket created"
else
  success "State bucket already exists"
fi
echo ""

# ── Init Terraform ─────────────────────────────────────────────────────────────

info "Initializing Terraform..."
cd "$REPO_ROOT/terraform"

terraform init -input=false -reconfigure \
  -backend-config="access_key=$HETZNER_S3_ACCESS_KEY" \
  -backend-config="secret_key=$HETZNER_S3_SECRET_KEY" 2>&1 | tail -3

success "Terraform initialized"
echo ""

# ── Create saves volume ────────────────────────────────────────────────────────

info "Creating persistent saves volume..."

REPO_URL="https://github.com/$REPO"

VOLUME_EXISTS=$(TF_VAR_hcloud_token="$HCLOUD_TOKEN" \
  TF_VAR_ssh_public_key="$(cat "$SSH_KEY.pub")" \
  TF_VAR_repo_url="$REPO_URL" \
  terraform state show hcloud_volume.saves 2>/dev/null && echo "exists" || echo "missing")

if [ "$VOLUME_EXISTS" = "exists" ]; then
  success "Saves volume already exists"
else
  TF_VAR_hcloud_token="$HCLOUD_TOKEN" \
  TF_VAR_ssh_public_key="$(cat "$SSH_KEY.pub")" \
  TF_VAR_repo_url="$REPO_URL" \
  terraform apply -auto-approve -input=false \
    -target=hcloud_volume.saves 2>&1 | tail -5
  success "Saves volume created"
fi
echo ""

# ── Set GitHub secrets ─────────────────────────────────────────────────────────

info "Setting GitHub Actions secrets..."
cd "$REPO_ROOT"

gh secret set HCLOUD_TOKEN           --body "$HCLOUD_TOKEN"
gh secret set HETZNER_S3_ACCESS_KEY  --body "$HETZNER_S3_ACCESS_KEY"
gh secret set HETZNER_S3_SECRET_KEY  --body "$HETZNER_S3_SECRET_KEY"
gh secret set SSH_PUBLIC_KEY         --body "$(cat "$SSH_KEY.pub")"
gh secret set SSH_PRIVATE_KEY        --body "$(cat "$SSH_KEY")"

success "All GitHub secrets set"
echo ""

# ── Write .env ─────────────────────────────────────────────────────────────────

cat > "$REPO_ROOT/.env" << EOF
HCLOUD_TOKEN=$HCLOUD_TOKEN
HETZNER_S3_ACCESS_KEY=$HETZNER_S3_ACCESS_KEY
HETZNER_S3_SECRET_KEY=$HETZNER_S3_SECRET_KEY
SSH_KEY=$SSH_KEY
REPO_URL=$REPO_URL
EOF

success ".env written for local make commands"
echo ""

# ── Done ───────────────────────────────────────────────────────────────────────

echo -e "${GREEN}${BOLD}  All done! Your server kit is ready.${RESET}"
echo ""
echo "  make start   spin up the server"
echo "  make stop    shut it down"
echo "  make ssh     SSH into the running server"
echo "  make logs    tail the server logs"
echo ""
echo "  Or trigger from GitHub: https://github.com/$REPO/actions"
echo ""
